# ── Neon PostgreSQL ─────────────────────────────────────────
# Obtenha em: neon.tech → Connection Details → Pooled connection
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# Conexão direta (usada apenas em migrations)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET="string-aleatoria-minimo-32-chars"

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
